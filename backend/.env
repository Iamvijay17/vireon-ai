# ── Server ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── MongoDB ─────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/vireon-ai

# ── Redis (BullMQ) ──────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── LM Studio (Gemma) ───────────────────────────────────
LM_STUDIO_URL=http://localhost:1234/v1/chat/completions
LM_STUDIO_MODEL=gemma
LM_STUDIO_TIMEOUT=60000
LM_STUDIO_MAX_RETRIES=3

# ── Pinokio F5-TTS ──────────────────────────────────────
TTS_API_URL=http://localhost:8000/generate
TTS_TIMEOUT=120000
TTS_MAX_RETRIES=3

# ── Remotion ────────────────────────────────────────────
REMOTION_BINARY=npx remotion
REMOTION_TIMEOUT=300000
REMOTION_MAX_RETRIES=2

# ── GitHub (Temporary Storage) ──────────────────────────
GITHUB_TOKEN=your-github-token
GITHUB_REPO_OWNER=your-username
GITHUB_REPO_NAME=vireon-ai-storage
GITHUB_BRANCH=main
GITHUB_UPLOAD_RETRIES=3

# ── CORS ────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── Rate Limiting ───────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
